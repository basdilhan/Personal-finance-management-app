<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Top Navigation Bar (Menu, Profile, Logout only) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Hamburger Menu Button (Left) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_menu"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_translucent"
                    android:contentDescription="Menu"
                    app:icon="@drawable/ic_menu"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Profile Button (Right) -->
                <ImageView
                    android:id="@+id/btn_profile"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/circle_translucent"
                    android:src="@drawable/ic_person"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Profile" />

                <!-- Logout Button (Right) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_logout"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/circle_translucent"
                    android:contentDescription="Logout"
                    app:icon="@drawable/ic_logout"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />
            </LinearLayout>

            <!-- Title Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bills_title"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="@string/bills_subtitle"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:alpha="0.9" />

            <!-- Total Due Amount Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/bills_total_due_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:alpha="0.85" />

                    <TextView
                        android:id="@+id/tv_total_due_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="LKR 0.00"
                        android:textColor="@color/error"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Bills and Empty State Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Bills RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_bills"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="20dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/tv_no_bills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/card_rounded_white"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/bills_empty_state"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:textAlignment="center"
                android:visibility="gone"
                android:padding="24dp" />
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
