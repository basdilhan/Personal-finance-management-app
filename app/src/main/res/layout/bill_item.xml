<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:elevation="2dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon Container with Status Indicator -->
        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="16dp">

            <!-- Background Circle -->
            <View
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_primary_light" />

            <!-- Icon -->
            <ImageView
                android:id="@+id/iv_bill_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:tint="@color/primary" />

            <!-- Status Indicator Dot -->
            <View
                android:id="@+id/status_indicator"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/circle_urgent" />
        </FrameLayout>

        <!-- Bill Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_bill_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Electricity Bill"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_due_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Due: Mar 07, 2026"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Amount -->
        <TextView
            android:id="@+id/tv_bill_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LKR 4500"
            android:textColor="@color/error"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
