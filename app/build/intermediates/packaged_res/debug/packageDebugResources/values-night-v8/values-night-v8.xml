    <color name="card_background_light">#273449</color>
    <color name="dashboard_chart_center">#E2E8F0</color>
    <color name="dashboard_chart_hole">#1E293B</color>
    <color name="dashboard_chart_other">#64748B</color>
    <color name="dashboard_header_subtitle">#C7D2FE</color>
    <color name="dashboard_insight_bg">#2A2110</color>
    <color name="dashboard_insight_body">#FCD34D</color>
